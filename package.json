{
  "name": "shareflow",
  "version": "1.0.0",
  "description": "ShareFlow - Share text and files across devices, instantly",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host",
    "dev:server": "tsx src/local.ts",
    "build": "vite build",
    "start": "tsx src/local.ts",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.4.0",
    "nanoid": "^5.0.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/markdown-it": "^14.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vue": "^3.4.0",
    "workbox-window": "^7.0.0",
    "wrangler": "^3.60.0"
  }
}
